# Safety & Trust engine -- environment for LIVE runs only.
# The offline `--demo` path needs none of these.
#
# Copy to `.env` and fill in. `.env` is gitignored. The PyRIT stage and garak
# Docker sidecar read these directly.

# --- Target model the stages red-team (provider chosen via --target-provider) ---
# OpenAI (also used by the garak Docker sidecar via --env-file .env)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o

# Azure OpenAI (for --target-provider azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_MODEL=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- PyRIT refusal-scorer judge (defaults to OpenAI) ---
# JUDGE_PROVIDER: openai | azure-openai
JUDGE_PROVIDER=openai
JUDGE_OPENAI_API_KEY=
JUDGE_OPENAI_MODEL=gpt-4o-mini
JUDGE_OPENAI_BASE_URL=https://api.openai.com/v1

# Azure judge (when JUDGE_PROVIDER=azure-openai)
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_DEPLOYMENT_NAME=
